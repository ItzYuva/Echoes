# ──────────────────────────────────────────────
# Echoes Data Pipeline -- Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ──── Reddit API ────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ──── Google Gemini ────
# Used for classification, tagging, intake, AND embeddings
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key

# ──── Qdrant (defaults work for local Docker) ────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ──── PostgreSQL (Phase 2 - user profiles) ────
# Run: docker compose up -d postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=echoes
POSTGRES_USER=echoes
POSTGRES_PASSWORD=echoes_dev

# ──── Phase 4: Agent Configuration ────
# Agent feature flag (set to false to disable Phase 4 entirely)
AGENT_ENABLED=true
AGENT_MAX_TOOL_CALLS=3
AGENT_SEARCH_TIMEOUT_SECONDS=30

# Reddit API for live search (optional — falls back to JSON endpoints if not set)
# These are separate from Phase 1's Reddit credentials above
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# Background enrichment (silently adds stories to Qdrant for medium-confidence queries)
AGENT_BACKGROUND_ENRICHMENT_ENABLED=true

# ──── Phase 5: Spring Boot API ────
# JWT signing secret (change in production!)
AUTH_TOKEN_SECRET=echoes-dev-secret-change-in-production-please
