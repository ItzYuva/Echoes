# ──────────────────────────────────────────────
# Echoes Data Pipeline -- Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ──── Reddit API ────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ──── Google Gemini ────
# Used for classification, tagging, intake, AND embeddings
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key

# ──── Qdrant (defaults work for local Docker) ────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ──── PostgreSQL (Phase 2 - user profiles) ────
# Run: docker compose up -d postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=echoes
POSTGRES_USER=echoes
POSTGRES_PASSWORD=echoes_dev
